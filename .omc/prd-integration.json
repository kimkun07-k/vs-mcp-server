{
  "project": "VS 2022 MCP Server — 실제 Visual Studio 통합 테스트",
  "description": "mock 없이 실제 VS 2022 인스턴스에 대해 각 기능을 검증",
  "stories": [
    {
      "id": "IT-001",
      "title": "VS 실행 및 인스턴스 감지",
      "acceptanceCriteria": [
        "ROT에서 VS 인스턴스를 찾아 PID와 모니커 반환 [PASS: pid=18872]",
        "모니커에서 추출한 PID가 tasklist devenv.exe와 일치 [PASS]",
        "get_vs_pid() 버그 수정 — win32process로 올바른 PID 반환 [PASS]",
        "스테일 ROT 항목 필터링 (_is_process_alive) [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-002",
      "title": "DTE 기본 속성 접근",
      "acceptanceCriteria": [
        "dte.MainWindow.Caption 접근 가능 [PASS]",
        "dte.Solution.FullName 반환 [PASS]",
        "dte.Version이 '17.' 로 시작 [PASS: '17.0']"
      ],
      "passes": true
    },
    {
      "id": "IT-003",
      "title": "파일 열기 (vs_file_open)",
      "acceptanceCriteria": [
        "vs_file_open status=='opened' [PASS]",
        "ActiveDocument.FullName이 config.py와 일치 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-004",
      "title": "열린 파일 목록 및 활성 파일",
      "acceptanceCriteria": [
        "vs_file_list_open 결과에 config.py 포함 [PASS]",
        "vs_file_active path/line/column 반환 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-005",
      "title": "빌드 상태 조회 (vs_build_status)",
      "acceptanceCriteria": [
        "build_state가 유효한 값 반환 [PASS: not_started]",
        "last_build_failed_projects가 정수 [PASS: -1]"
      ],
      "passes": true
    },
    {
      "id": "IT-006",
      "title": "브레이크포인트 CRUD (vs_debug_breakpoint)",
      "acceptanceCriteria": [
        "list 반환 [PASS]",
        "add 후 list 확인 [PASS]",
        "remove 후 list에서 삭제 확인 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-007",
      "title": "디버거 모드 확인",
      "acceptanceCriteria": [
        "Debugger.CurrentMode==1 (Design) [PASS]",
        "vs_debug_stop() -> 'not_debugging' [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-008",
      "title": "실제 STAThread 큐 경로 검증",
      "acceptanceCriteria": [
        "STAThread 내부 STA에서 ROT DTE 재획득 후 Version 반환 [PASS: '17.0']",
        "STAThread 명령 이력(get_history)에 done 상태로 기록 [PASS]",
        "cross-apartment 문제(RPC_E_WRONG_THREAD) 없이 실행 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-009",
      "title": "파일 커서 이동 (vs_file_goto)",
      "acceptanceCriteria": [
        "vs_file_goto status=='moved' [PASS]",
        "vs_file_active 결과 line이 target_line(3)과 일치 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-010",
      "title": "범위 하이라이트 (vs_file_highlight)",
      "acceptanceCriteria": [
        "vs_file_highlight status=='highlighted' [PASS]",
        "start_line=1, end_line=2 반환 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-011",
      "title": "선택 텍스트 조회 (vs_file_selection)",
      "acceptanceCriteria": [
        "vs_file_selection path/start_line/end_line/text 반환 [PASS]",
        "IT-010 highlight 후 lines 1-2의 텍스트가 포함됨 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-012",
      "title": "실제 디버거 attach + Break 모드 진입",
      "acceptanceCriteria": [
        "새 VS 인스턴스에 DebugTarget.sln 로드 및 Debug 빌드 완료 [PASS]",
        "Program.cs:5에 브레이크포인트 추가 후 vs_debug_start 호출 [PASS]",
        "30초 이내 Break 모드(CurrentMode==2) 진입 확인 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-013",
      "title": "Break 모드에서 로컬 변수 조회 (vs_debug_locals)",
      "acceptanceCriteria": [
        "vs_debug_locals가 x, y, msg 변수 반환 [PASS]",
        "x==42, y==50 값 확인 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-014",
      "title": "Break 모드에서 표현식 평가 (vs_debug_evaluate)",
      "acceptanceCriteria": [
        "evaluate('x + y') == '92' [PASS]",
        "evaluate('msg')에 'hello from debugger' 포함 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-015",
      "title": "Break 모드에서 콜스택 조회 (vs_debug_callstack)",
      "acceptanceCriteria": [
        "vs_debug_callstack이 최소 1개 프레임 반환 [PASS: depth=1]",
        ".NET 8에서 StackFrames 순회 실패 시 CurrentStackFrame 폴백 동작 [PASS: 'Program.<Main>$']",
        "도구가 크래시 없이 유효한 구조 반환 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-016",
      "title": "Break 모드에서 Step Over (vs_debug_step)",
      "acceptanceCriteria": [
        "vs_debug_step('over') 후 mode=='break' [PASS]",
        "step 후 line이 BP_LINE(5)보다 크거나 같음 [PASS: line=6]",
        ".NET 8에서 frame.FileName 실패 시 ActiveDocument 폴백 동작 [PASS]"
      ],
      "passes": true
    },
    {
      "id": "IT-017",
      "title": "Break 모드에서 디버거 중단 (vs_debug_stop)",
      "acceptanceCriteria": [
        "vs_debug_stop() status=='stopped' [PASS]",
        "mode=='design' 복귀 확인 [PASS]"
      ],
      "passes": true
    }
  ]
}
